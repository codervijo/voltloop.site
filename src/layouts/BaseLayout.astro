---
const {
  title = 'Voltloop — EV Charging Cost Calculators',
  description = 'Free EV charging cost calculators. Estimate the real cost to charge any electric vehicle at home or at a Supercharger.',
  canonical
} = Astro.props;

const site = Astro.site || new URL('https://voltloop.site');
const canonicalUrl = canonical || new URL(Astro.url.pathname, site).toString();
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="Voltloop" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <style is:global>
      :root { color-scheme: light; }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f7f8fa;
        color: #0f172a;
        -webkit-font-smoothing: antialiased;
        line-height: 1.55;
      }
      a { color: #0b65d6; text-decoration: none; }
      a:hover { text-decoration: underline; }
      header.site, footer.site, main {
        max-width: 880px;
        margin: 0 auto;
      }
      header.site {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px;
      }
      header.site .brand {
        font-weight: 700;
        font-size: 1.2rem;
        color: #0f172a;
      }
      header.site nav a {
        margin-left: 14px;
        font-weight: 500;
        font-size: 0.95rem;
        color: #334155;
      }
      main { padding: 16px 16px 64px; }
      footer.site {
        padding: 24px 16px 48px;
        color: #64748b;
        font-size: 0.85rem;
      }
      h1 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        line-height: 1.15;
        margin: 8px 0 12px;
        font-weight: 700;
      }
      h2 {
        font-size: 1.4rem;
        margin: 32px 0 8px;
        font-weight: 600;
      }
      p.lede {
        font-size: 1.1rem;
        color: #334155;
      }
      ul.related { padding-left: 20px; }
      ul.related li { margin-bottom: 6px; }
      table.compare {
        width: 100%;
        border-collapse: collapse;
        margin: 16px 0;
        font-size: 0.95rem;
      }
      table.compare th, table.compare td {
        text-align: left;
        padding: 8px 4px;
        border-bottom: 1px solid #e2e8f0;
      }
      table.compare th { color: #475569; font-weight: 600; }
      @media (max-width: 480px) {
        header.site { flex-direction: column; align-items: flex-start; }
        header.site nav a { margin-left: 0; margin-right: 14px; }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/">⚡ Voltloop</a>
      <nav>
        <a href="/">Home</a>
        <a href="/ev-charging-cost-calculator">Calculator</a>
        <a href="/tesla-supercharger-cost">Supercharger</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      © {year} Voltloop. Estimates only — actual cost varies by utility, vehicle, weather, and charging losses.
    </footer>
  </body>
</html>
